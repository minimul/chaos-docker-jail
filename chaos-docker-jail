#!/bin/bash
# chaos-docker-jail - run seuros/chaos (https://github.com/seuros/chaos)
# inside a sandboxed Docker container.
#
# This script is based on the local claude-jail wrapper, but is tailored for
# Chaos. In Claude MAX mode, Chaos shells out to Claude Code, so we reuse the
# host's Claude auth directory to preserve login state across runs. Chaos state
# is stored separately under ~/.chaos-home.
set -eo pipefail

IMAGE_NAME="chaos-docker-jail"
HOST_PWD="$(pwd)"
SCRIPT_PATH="$(readlink -f "$0")"
CHAOS_REF="${CHAOS_REF:-master}"
FORCE_REBUILD=false
NO_CACHE=false
SHELL_MODE=false
SAFE_MODE=false
PASSTHROUGH_ARGS=()
ENV_VARS=()
: "${USER:=$(id -un)}"

while [[ $# -gt 0 ]]; do
    case $1 in
        --rebuild|-r) FORCE_REBUILD=true; shift ;;
        --no-cache)   NO_CACHE=true; shift ;;
        --shell|-s)   SHELL_MODE=true; shift ;;
        --safe)       SAFE_MODE=true; shift ;;
        -e|--env)
            [ -z "${2:-}" ] && { echo "Error: $1 requires KEY=VALUE" >&2; exit 1; }
            ENV_VARS+=("$2"); shift 2 ;;
        --help|-h)
            cat <<EOF
Usage: $0 [OPTIONS] [-- CHAOS_ARGS...]

Options:
  -e, --env KEY=VAL   Pass env var to the container (repeatable)
  -r, --rebuild       Force rebuild of the Docker image
      --no-cache      Rebuild without Docker cache
  -s, --shell         Start a bash shell instead of chaos
      --safe          Disable default YOLO mode
  -h, --help          Show this help

Environment:
  CHAOS_REF           git ref of seuros/chaos to build (default: master)

Mounts:
  \$HOME/.claude-home  -> /home/node/.claude  (shared Claude auth state)
  \$HOME/.chaos-home   -> /home/node/.chaos
  \$(pwd)              -> \$(pwd)              (workspace)
EOF
            exit 0 ;;
        --) shift; PASSTHROUGH_ARGS+=("$@"); break ;;
        *)  echo "Error: Unknown option '$1'" >&2; exit 1 ;;
    esac
done

# Shared Claude auth state from the host.
claude_data="$HOME/.claude-home"
mkdir -p "$claude_data/.claude"
touch "$claude_data/.claude.json"

# Persistent Chaos state on the host.
chaos_data="$HOME/.chaos-home"
mkdir -p "$chaos_data/.chaos" "$chaos_data/.codex"

SCRIPT_HASH=$(md5sum "$SCRIPT_PATH" | cut -d' ' -f1)
BUILD_KEY="${SCRIPT_HASH}:${CHAOS_REF}"

NEEDS_BUILD=false
if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
    echo "Image '$IMAGE_NAME' not found. Building..."
    NEEDS_BUILD=true
elif [ "$FORCE_REBUILD" = true ] || [ "$NO_CACHE" = true ]; then
    NEEDS_BUILD=true
else
    STORED=$(docker image inspect "$IMAGE_NAME" --format '{{index .Config.Labels "chaos.build.key"}}' 2>/dev/null || true)
    [ "$STORED" != "$BUILD_KEY" ] && { echo "Build inputs changed. Rebuilding..."; NEEDS_BUILD=true; }
fi

if [ "$NEEDS_BUILD" = true ]; then
    BUILD_DIR=$(mktemp -d)
    cat > "$BUILD_DIR/Dockerfile" <<'DOCKERFILE'
FROM rust:1.94-bookworm AS builder
ARG CHAOS_REF=master
RUN apt-get update && apt-get install -y --no-install-recommends \
        git ca-certificates pkg-config libssl-dev clang libdbus-1-dev \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /src
RUN git clone https://github.com/seuros/chaos.git
WORKDIR /src/chaos
RUN git checkout "$CHAOS_REF"
RUN git submodule update --init --recursive || \
    echo "WARN: submodule update failed; continuing without submodules"
RUN cargo build --release -p chaos-cli --bin chaos
RUN cp target/release/chaos /usr/local/bin/chaos

FROM node:22-bookworm
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl git jq libssl3 libdbus-1-3 gnupg \
    && rm -rf /var/lib/apt/lists/*
# Install the Docker CLI + compose plugin from Docker's official repo.
RUN apt-get update \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg \
        | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && chmod a+r /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian bookworm stable" \
        > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        docker-ce-cli docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*
# Move the real docker binary out of $PATH and replace it with a filtering shim.
RUN install -d /usr/local/libexec \
    && mv /usr/bin/docker /usr/local/libexec/docker-real
# Claude Code is installed because Chaos shells out to it for Claude MAX auth.
RUN npm install -g @anthropic-ai/claude-code
COPY --from=builder /usr/local/bin/chaos /usr/local/bin/chaos
COPY docker-shim /usr/local/bin/docker
RUN chmod 0755 /usr/local/bin/docker
WORKDIR /workspace
CMD ["chaos"]
DOCKERFILE

    cat > "$BUILD_DIR/docker-shim" <<'SHIM'
#!/bin/bash
# chaos-docker-jail docker shim
#
# Filters access to the host docker daemon so that, from inside the jail, only
# containers belonging to the compose project rooted at this directory can be
# inspected, exec'd into, started, stopped, etc. Host-wide operations
# (run/create/build/network/volume/system/...) are blocked outright.

set -uo pipefail

REAL_DOCKER="/usr/local/libexec/docker-real"
WORKDIR="${CHAOS_DOCKER_JAIL_COMPOSE_WORKDIR:-$PWD}"
SHIM_NAME="chaos-docker-jail docker shim"

if ! [ -x "$REAL_DOCKER" ]; then
    echo "$SHIM_NAME: real docker binary missing at $REAL_DOCKER" >&2
    exit 127
fi

deny() {
    echo "$SHIM_NAME: refusing $*" >&2
    echo "$SHIM_NAME: scope = compose project working_dir=$WORKDIR" >&2
    exit 1
}

allowed_refs() {
    "$REAL_DOCKER" ps -a \
        --filter "label=com.docker.compose.project.working_dir=$WORKDIR" \
        --format '{{.Names}}{{"\t"}}{{.ID}}' 2>/dev/null \
    | awk -F'\t' 'NF>=2 { print $1; print $2; print substr($2,1,12) }'
}

_ALLOW_CACHE=""
get_allow() {
    if [ -z "$_ALLOW_CACHE" ]; then
        _ALLOW_CACHE="$(allowed_refs)"
        if [ -z "$_ALLOW_CACHE" ]; then
            _ALLOW_CACHE="__none__"
        fi
    fi
    [ "$_ALLOW_CACHE" = "__none__" ] || printf '%s\n' "$_ALLOW_CACHE"
}

is_allowed_ref() {
    local target="$1"
    [ -z "$target" ] && return 1
    get_allow | grep -qxF "$target"
}

verify_targets() {
    local arg ref
    local found_any=0
    for arg in "$@"; do
        case "$arg" in
            ''|--|-*) continue ;;
        esac
        ref="${arg%%:*}"
        if "$REAL_DOCKER" inspect --type=container "$ref" >/dev/null 2>&1; then
            found_any=1
            if ! is_allowed_ref "$ref"; then
                deny "container '$ref' is out of scope"
            fi
        fi
    done
    if [ "$found_any" = "0" ]; then
        deny "no in-scope container found in arguments"
    fi
}

CMD="${1:-}"

case "$CMD" in
    ''|help|--help|-h|version|--version|-v|info)
        exec "$REAL_DOCKER" "$@"
        ;;
esac

case "$CMD" in
    run|create|pull|push|build|buildx|builder|\
    image|images|rmi|save|load|import|export|tag|history|\
    network|volume|system|swarm|node|service|stack|secret|config|plugin|\
    context|login|logout|trust|search|commit|init|checkpoint)
        deny "'docker $CMD' is host-wide and not allowed from inside chaos-docker-jail"
        ;;
esac

if [ "$CMD" = "ps" ]; then
    shift
    exec "$REAL_DOCKER" ps \
        --filter "label=com.docker.compose.project.working_dir=$WORKDIR" "$@"
fi

if [ "$CMD" = "stats" ]; then
    shift
    has_positional=0
    skip_next=0
    for arg in "$@"; do
        if [ "$skip_next" = "1" ]; then skip_next=0; continue; fi
        case "$arg" in
            --format|--format=*) [ "$arg" = "--format" ] && skip_next=1 ;;
            --) continue ;;
            -*) ;;
            *) has_positional=1; break ;;
        esac
    done
    if [ "$has_positional" = "0" ]; then
        ids=$("$REAL_DOCKER" ps -q \
            --filter "label=com.docker.compose.project.working_dir=$WORKDIR" 2>/dev/null)
        if [ -z "$ids" ]; then
            deny "no in-scope containers to stats"
        fi
        # shellcheck disable=SC2086
        exec "$REAL_DOCKER" stats "$@" $ids
    fi
    verify_targets "$@"
    exec "$REAL_DOCKER" stats "$@"
fi

if [ "$CMD" = "compose" ]; then
    shift
    for arg in "$@"; do
        case "$arg" in
            -f|--file|-f=*|--file=*|\
            --project-directory|--project-directory=*|\
            -p|--project-name|-p=*|--project-name=*|\
            --env-file|--env-file=*)
                deny "compose flag '$arg' would escape the project scope"
                ;;
        esac
    done
    cd "$WORKDIR" 2>/dev/null || true
    exec "$REAL_DOCKER" compose "$@"
fi

case "$CMD" in
    exec|logs|inspect|top|stats|port|diff|\
    kill|stop|start|restart|pause|unpause|\
    rename|update|cp|wait|attach|rm)
        shift
        verify_targets "$@"
        exec "$REAL_DOCKER" "$CMD" "$@"
        ;;
esac

deny "'docker $CMD' is not recognized by the shim"
SHIM
    chmod +x "$BUILD_DIR/docker-shim"

    BUILD_ARGS=(
      --build-arg "CHAOS_REF=$CHAOS_REF"
      --label "chaos.build.key=$BUILD_KEY"
      -t "$IMAGE_NAME"
    )
    [ "$NO_CACHE" = true ] && BUILD_ARGS+=(--no-cache)
    docker build "${BUILD_ARGS[@]}" "$BUILD_DIR"
    rm -rf "$BUILD_DIR"
fi

detect_compose_containers() {
    docker ps -a \
        --filter "label=com.docker.compose.project.working_dir=$HOST_PWD" \
        --format '{{.Names}}' 2>/dev/null
}

detect_compose_networks() {
    local cids cid
    cids=$(docker ps -q --filter "label=com.docker.compose.project.working_dir=$HOST_PWD" 2>/dev/null)
    if [ -z "$cids" ]; then
        return
    fi
    for cid in $cids; do
        docker inspect "$cid" \
            --format '{{range $name, $_ := .NetworkSettings.Networks}}{{$name}}{{"\n"}}{{end}}' \
            2>/dev/null
    done | awk 'NF && !seen[$0]++'
}

mapfile -t COMPOSE_CONTAINERS < <(detect_compose_containers)
mapfile -t COMPOSE_NETWORKS < <(detect_compose_networks)

if [ ${#COMPOSE_CONTAINERS[@]} -gt 0 ]; then
    echo "Compose containers in scope: ${COMPOSE_CONTAINERS[*]}"
else
    echo "Warning: no running compose containers detected for $HOST_PWD" >&2
fi

TTY_FLAGS=(-i)
[ -t 0 ] && [ -t 1 ] && TTY_FLAGS+=(-t)

HOST_DOCKER_SOCK=""
for candidate in /var/run/docker.sock /run/docker.sock; do
    if [ -S "$candidate" ]; then
        HOST_DOCKER_SOCK="$candidate"
        break
    fi
done
if [ -z "$HOST_DOCKER_SOCK" ]; then
    echo "Warning: no docker socket found at /var/run/docker.sock or /run/docker.sock;" >&2
    echo "         docker commands inside the jail will fail." >&2
fi
DOCKER_SOCK_GID=""
if [ -n "$HOST_DOCKER_SOCK" ]; then
    DOCKER_SOCK_GID=$(stat -c '%g' "$HOST_DOCKER_SOCK" 2>/dev/null || true)
fi

DOCKER_ARGS=(
  "${TTY_FLAGS[@]}" --rm
  --user "$(id -u):$(id -g)"
  --cap-drop=ALL
  --security-opt=no-new-privileges
  --label "hostdir=$HOST_PWD"
  -v "$HOST_PWD:$HOST_PWD"
  -v "$claude_data/.claude:/home/node/.claude"
  -v "$claude_data/.claude.json:/home/node/.claude.json"
  -v "$chaos_data/.chaos:/home/node/.chaos"
  -v "$chaos_data/.codex:/home/node/.codex"
  -w "$HOST_PWD"
  -e HOME=/home/node
  -e "CHAOS_DOCKER_JAIL_COMPOSE_WORKDIR=$HOST_PWD"
  -e CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1
  -e CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
  -e DISABLE_AUTOUPDATER=1
)
if [ -n "$HOST_DOCKER_SOCK" ]; then
    DOCKER_ARGS+=(-v "$HOST_DOCKER_SOCK:/var/run/docker.sock")
fi
if [ -n "$DOCKER_SOCK_GID" ]; then
    DOCKER_ARGS+=(--group-add "$DOCKER_SOCK_GID")
fi
if [ ${#COMPOSE_NETWORKS[@]} -gt 0 ]; then
    DOCKER_ARGS+=(--network "${COMPOSE_NETWORKS[0]}")
fi
for env_var in "${ENV_VARS[@]}"; do
    DOCKER_ARGS+=(-e "$env_var")
done

# Forward host Anthropic credentials into the container when present.
# Intentionally do not forward ANTHROPIC_API_KEY by default so Chaos prefers
# clamped Claude Code MAX auth when available.
for k in ANTHROPIC_AUTH_TOKEN ANTHROPIC_BASE_URL; do
    if [ -n "${!k:-}" ]; then
        DOCKER_ARGS+=(-e "$k=${!k}")
    fi
done

JAIL_CID=""
cleanup_jail() {
    if [ -n "$JAIL_CID" ]; then
        docker rm -f "$JAIL_CID" >/dev/null 2>&1 || true
    fi
}
trap cleanup_jail EXIT

if [ "$SHELL_MODE" = true ]; then
    EXISTING=$(docker ps -q --filter "label=hostdir=$HOST_PWD" --filter "ancestor=$IMAGE_NAME" | head -1)
    if [ -n "$EXISTING" ]; then
        trap - EXIT
        exec docker exec "${TTY_FLAGS[@]}" "$EXISTING" bash
    fi
fi

CHAOS_CMD=(chaos)
[ "$SAFE_MODE" = false ] && CHAOS_CMD+=(--dangerously-bypass-approvals-and-sandbox)

set +e
if [ ${#PASSTHROUGH_ARGS[@]} -gt 0 ]; then
    JAIL_CID=$(docker create "${DOCKER_ARGS[@]}" "$IMAGE_NAME" "${CHAOS_CMD[@]}" "${PASSTHROUGH_ARGS[@]}")
elif [ "$SHELL_MODE" = true ]; then
    JAIL_CID=$(docker create "${DOCKER_ARGS[@]}" "$IMAGE_NAME" bash)
else
    JAIL_CID=$(docker create "${DOCKER_ARGS[@]}" "$IMAGE_NAME" "${CHAOS_CMD[@]}")
fi
CREATE_RC=$?
set -e

if [ "$CREATE_RC" -ne 0 ] || [ -z "$JAIL_CID" ]; then
    echo "ERROR: docker create failed (status $CREATE_RC)" >&2
    exit "${CREATE_RC:-1}"
fi

for ((i=1; i<${#COMPOSE_NETWORKS[@]}; i++)); do
    if ! docker network connect "${COMPOSE_NETWORKS[$i]}" "$JAIL_CID" >/dev/null 2>&1; then
        echo "Warning: failed to attach to network '${COMPOSE_NETWORKS[$i]}'" >&2
    fi
done

set +e
docker start -a -i "$JAIL_CID"
RUN_RC=$?
set -e

if [ "${RUN_RC:-0}" -ne 0 ]; then
    echo "chaos container exited with status ${RUN_RC}" >&2
fi
exit "${RUN_RC:-0}"
